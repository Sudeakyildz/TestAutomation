# GitSec Test Otomasyon — ortam değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

E2E_USER_EMAIL=your-email@example.com
E2E_USER_PASSWORD=your-password

# GitSec workspace ID (dashboard URL'deki sayı)
WORKSPACE_ID=83

# UI ve API taban adresleri
DASHBOARD_BASE_URL=https://staging.dashboard.gitsec.io
API_BASE_URL=https://staging.api.gitsec.io

# GitHub E2E (opsiyonel — test_4–7)
GITHUB_TEST_USER=
GITHUB_TEST_PASSWORD=
GITHUB_MAIL_USER=
GITHUB_MAIL_PASSWORD=

# Davet write testleri için rol ID (staging'de Member=4 genelde çalışır)
E2E_INVITE_ROLE_ID=4
